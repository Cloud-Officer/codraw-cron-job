{
    "name": "codraw/cron-job",
    "description": "This component allows to manage cron jobs.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "draw",
        "cronjob",
        "cron",
        "cron job"
    ],
    "authors": [
        {
            "name": "Martin Poirier Theoret",
            "email": "mpoiriert@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "doctrine/collections": "^2.2",
        "doctrine/orm": "^3.6",
        "doctrine/persistence": "^2.2 || ^3.0",
        "dragonmantank/cron-expression": "^3.3",
        "codraw/core": "^0.39",
        "codraw/messenger": "^0.39",
        "codraw/process": "^0.39",
        "psr/log": "^3",
        "symfony/amqp-messenger": "^6.4.0",
        "symfony/console": "^6.4.0",
        "symfony/dependency-injection": "^6.4.0",
        "symfony/event-dispatcher": "^6.4.0",
        "symfony/messenger": "^6.4.0",
        "symfony/validator": "^6.4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.3 || ^12.0",
        "codraw/dependency-injection": "^0.39",
        "codraw/tester": "^0.39",
        "nesbot/carbon": "^3.8"
    },
    "suggest": {
        "codraw/framework-extra-bundle": "To integrate in Symfony"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Draw\\Component\\CronJob\\": ""
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.39-dev"
        }
    },
    "replace": {
        "draw/cron-job": "self.version"
    }
}
